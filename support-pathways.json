{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nwo-dao.org/schemas/wellbeing/support-pathways.json",
  "title": "SupportPathways",
  "description": "Structured, non-punitive, trauma-preventive support pathways generated by the Wellbeing Engine.",

  "type": "object",

  "properties": {
    "pathway_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this support pathway."
    },

    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Time the support pathway was generated."
    },

    "source": {
      "type": "object",
      "description": "References to the inputs that produced this pathway.",
      "properties": {
        "wellbeing_model_id": { "type": "string" },
        "harm_prevention_id": { "type": "string" },
        "predictive_action_id": { "type": "string" },
        "identity_context_id": { "type": "string" },
        "environment_context_id": { "type": "string" }
      }
    },

    "stability_score": {
      "type": "number",
      "minimum": -1,
      "maximum": 1,
      "description": "Overall predicted effect on stability (-1 = destabilizing, 1 = stabilizing)."
    },

    "priority_level": {
      "type": "string",
      "enum": ["low", "moderate", "high", "critical"],
      "description": "Urgency level for implementing the support pathway."
    },

    "affected_identities": {
      "type": "array",
      "description": "Identities or groups impacted by this pathway.",
      "items": {
        "type": "object",
        "properties": {
          "identity_id": { "type": "string" },
          "role": { "type": "string" },
          "needs": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["identity_id"]
      }
    },

    "pathway_steps": {
      "type": "array",
      "description": "Ordered steps that form the support pathway.",
      "items": {
        "type": "object",
        "properties": {
          "step_id": { "type": "string" },
          "step_type": {
            "type": "string",
            "enum": [
              "emotional_support",
              "resource_connection",
              "environmental_adjustment",
              "stability_planning",
              "community_support",
              "de-escalation_support",
              "identity_reinforcement",
              "predictive_feedback"
            ]
          },
          "description": { "type": "string" },
          "expected_outcome": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["step_type", "description"]
      }
    },

    "safeguards": {
      "type": "array",
      "description": "Harm-prevention safeguards applied to this pathway.",
      "items": {
        "type": "object",
        "properties": {
          "safeguard_type": {
            "type": "string",
            "enum": [
              "dignity_protection",
              "emotional_safety",
              "environmental_stability",
              "supportive_intervention",
              "consent_verification",
              "non_escalation_protocol"
            ]
          },
          "description": { "type": "string" }
        },
        "required": ["safeguard_type"]
      }
    },

    "feedback_channels": {
      "type": "object",
      "description": "Where this pathway is routed for execution and monitoring.",
      "properties": {
        "governance_kernel": { "type": "boolean" },
        "predictive_engine": { "type": "boolean" },
        "registry_service": { "type": "boolean" },
        "identity_kernel": { "type": "boolean" },
        "audit_layer": { "type": "boolean" }
      }
    },

    "signature": {
      "type": "object",
      "description": "Cryptographic signature ensuring authenticity and integrity.",
      "properties": {
        "algorithm": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["algorithm", "value"]
    }
  },

  "required": [
    "pathway_id",
    "timestamp",
    "stability_score",
    "priority_level",
    "pathway_steps",
    "safeguards",
    "signature"
  ]
}
